__pycache__/
*.pyc

# Machine-local tool state (not source)
.wrangler/
.claude/

# Raw research/session transcripts — kept on disk, not published
_research/
_not_needed/

.DS_Store

# npm (only used for local tooling; not part of the static app)
node_modules/
package-lock.json
package.json
